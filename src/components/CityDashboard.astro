---
// City dashboard — the granular layer. A region-grouped selector drives three
// client-rendered charts fetched on demand from /data/cities/<id>.json:
//   • this year vs the 1991-2020 normal (daily band)   • monthly anomaly heatmap
//   • the city's own annual warming line
import index from "../data/cities-index.json";
import projection from "../data/projection.json";
import Explainer from "./Explainer.astro";

const cities = index.cities as Array<{
  id: string; name: string; region: string; lat: number; lon: number;
  latestAnomaly: number | null; latestYear: number;
}>;
const REGION_ORDER = ["North", "Himalaya", "West", "Central", "East", "Northeast", "South", "Other"];
const grouped = REGION_ORDER
  .map((r) => ({ region: r, items: cities.filter((c) => c.region === r) }))
  .filter((g) => g.items.length);
const defaultCity = cities.find((c) => c.id === "delhi")?.id ?? cities[0].id;
const defaultCityName = cities.find((c) => c.id === defaultCity)?.name ?? "";
const sortedCities = [...cities].sort((a, b) => a.name.localeCompare(b.name));
---

<section class="section city-dash" data-default={defaultCity} data-default-name={defaultCityName}>
  <script type="application/json" data-projection set:html={JSON.stringify(projection)}></script>
  <div class="city-head">
    <div class="section-head">
      <p class="eyebrow">Your city</p>
      <h2>Down to the day, where you live</h2>
      <p class="standfirst">
        How this year is tracking against the 1991–2020 normal, the warming fingerprint
        month by month, and the long trend.
      </p>
    </div>
    <div class="picker">
      <span>Search a city</span>
      <div class="combo" data-combo>
        <input type="text" class="combo-input" placeholder={`Type any of ${cities.length} cities…`}
               aria-label="Search for a city" autocomplete="off" spellcheck="false" />
        <ul class="combo-list" data-combo-list hidden>
          {sortedCities.map((c) => (
            <li class="combo-opt" data-id={c.id} data-search={c.name.toLowerCase()}>
              <span class="opt-name">{c.name}</span><span class="opt-region">{c.region}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="city-views" data-views>
    <p class="city-meta mono" data-meta></p>

    <div class="city-stats" data-stats></div>

    <div class="panel">
      <div class="panel-top">
        <div>
          <h3 data-band-title>This year vs normal</h3>
          <p class="hint" data-band-hint>Every year since 1950 as a faint line; the recent years picked out. Hover to read any day.</p>
        </div>
        <div class="seg" data-bandmode role="tablist" aria-label="Chart mode">
          <button data-mode="spaghetti" class="on" type="button">Every year</button>
          <button data-mode="band" type="button">Normal band</button>
        </div>
      </div>
      <div class="chart band" data-band></div>
      <div class="legend" data-band-legend></div>
      <Explainer>
        Every faint line is one whole year of daily temperature for this city, stacked on top of
        each other so you see the seasons. The <strong>bold line is now</strong>. When today's line
        rides along the upper edge of the crowd, the city is running hotter than almost any year on
        record. When it dips into the pile, it is an ordinary day by history's standards.
      </Explainer>
    </div>

    <div class="grid2">
      <div class="panel">
        <h3>Warming, month by month</h3>
        <p class="hint">Each cell is one month's anomaly vs its 1991–2020 normal. Cool blue to warm ember. Hover a cell.</p>
        <div class="chart heat" data-heat></div>
        <Explainer>
          Each little block is one month of one year, coloured against that month's own normal:
          blue if it came in cooler, ember if warmer. Pick any row and scan left to right. If the
          blues fade out and the <strong>reds take over as you reach today</strong>, that month has
          been heating up. The whole grid blushing red on the right is the warming, made visible.
        </Explainer>
      </div>
      <div class="panel">
        <h3>The long trend, and the road to 2050</h3>
        <p class="hint">Annual average temperature vs the 1991–2020 normal, with a ten-year trend
          and the CMIP6 climate-model projection ahead.</p>
        <div class="chart annual" data-annual></div>
        <Explainer>
          The same city, zoomed out to a single number a year. The thin jagged line is each year's
          wobble; the thick soft band underneath is the ten-year drift. <strong>The wobble is
          weather. The drift is climate.</strong> A cool year here and there is normal. The slow,
          steady rise of the band beneath them is the part that doesn't reverse.
        </Explainer>
        <Explainer tag="About that projection cone">
          The dashed line and shaded cone after today are <strong>not a forecast for this exact
          city</strong>. They're the CMIP6 climate models' projection for <strong>India as a
          whole</strong> — the range between an intermediate (SSP2-4.5) and a high (SSP5-8.5)
          emissions path — added on top of where this city sits now. Climate models work at a
          coarse, roughly 25&nbsp;km grid, so a single city's future essentially tracks its
          region's; treat the cone as <strong>"how much hotter the neighbourhood gets,"</strong>
          not a number for your street. The cone widens because the further out you go, the more
          our emissions choices (not the science) decide the outcome.
        </Explainer>
      </div>
    </div>

    <div class="panel">
      <h3>Humid heat: the danger is how it <em>feels</em></h3>
      <p class="hint" data-hheat-hint>Days each year that felt like 40°C or hotter once you fold in humidity (apparent temperature). The darker base is the truly dangerous "felt like 45°C and up" days.</p>
      <div class="chart hheat" data-hheat></div>
      <div class="legend" data-hheat-legend></div>
      <Explainer>
        A thermometer reading hides the real threat. When the air is humid, sweat can't evaporate,
        so your body loses its only way to cool itself, and a "feels like" number well above the
        actual temperature is what sends people to hospital. <strong>India's killer is humid heat,
        not dry heat</strong>, and these bars are climbing in almost every city. Hill stations and
        the deep-cool south barely register, which is exactly why people flee to them.
      </Explainer>
    </div>

    <p class="fignote" data-src></p>
  </div>
</section>

<!-- Global (not scoped): the stats, legend chips, tooltip and SVGs are created in
     JS and never get Astro's scope attribute, so scoped styles wouldn't reach them.
     Everything is namespaced under .city-dash to avoid leaking. -->
<style is:global>
  .city-dash .city-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 28px; flex-wrap: wrap; }
  .city-dash .city-head .section-head { margin-bottom: 0; }
  .city-dash .picker { display: flex; flex-direction: column; gap: 8px; flex-shrink: 0;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-faint); }
  .city-dash .combo { position: relative; }
  .city-dash .combo-input {
    font-family: var(--serif); font-size: 21px; font-weight: 500; color: var(--ink);
    padding: 11px 16px; border: 1.5px solid var(--line); border-radius: 9px;
    background: var(--paper); width: 270px; max-width: 100%;
    transition: border-color .2s var(--ease), box-shadow .2s var(--ease);
  }
  .city-dash .combo-input::placeholder { color: var(--ink-faint); font-size: 15px; font-style: italic; }
  .city-dash .combo-input:hover { border-color: var(--ember); }
  .city-dash .combo-input:focus-visible { outline: none; border-color: var(--ember); box-shadow: 0 0 0 4px var(--ember-tint); }
  .city-dash .combo-list {
    position: absolute; z-index: 20; top: calc(100% + 6px); left: 0; right: 0;
    max-height: 330px; overflow-y: auto; margin: 0; padding: 6px; list-style: none;
    background: var(--paper); border: 1px solid var(--line); border-radius: 10px;
    box-shadow: 0 20px 44px -22px rgba(27,22,19,.55);
  }
  .city-dash .combo-opt {
    display: flex; justify-content: space-between; align-items: baseline; gap: 12px;
    padding: 8px 11px; border-radius: 6px; cursor: pointer;
  }
  .city-dash .combo-opt:hover, .city-dash .combo-opt.active { background: var(--panel); }
  .city-dash .combo-opt .opt-name { font-family: var(--serif); font-size: 16px; color: var(--ink); }
  .city-dash .combo-opt .opt-region { font-family: var(--mono); font-size: 10px; letter-spacing: .08em;
    text-transform: uppercase; color: var(--ink-faint); white-space: nowrap; }

  .city-dash .city-views { transition: opacity .28s var(--ease); }
  .city-dash .city-views.swapping { opacity: 0; }

  .city-dash .city-meta { font-size: 13px; color: var(--ink-faint); margin: 30px 0 0; letter-spacing: 0.02em; }
  .city-dash .city-meta b { color: var(--ink); font-weight: 600; }

  .city-dash .city-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 18px 28px; margin: 18px 0 6px; }
  .city-dash .city-stats .s { display: flex; flex-direction: column; gap: 5px; }
  .city-dash .city-stats .s .v { font-family: var(--mono); font-size: 28px; font-weight: 600; line-height: 1.05;
    color: var(--ink); font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }
  .city-dash .city-stats .s.warm .v { color: var(--ember); }
  .city-dash .city-stats .s .k { font-size: 13px; line-height: 1.45; color: var(--ink-soft); }

  .city-dash .panel { margin-top: 38px; }
  .city-dash .panel-top { display: flex; justify-content: space-between; align-items: flex-start;
    gap: 18px; flex-wrap: wrap; margin-bottom: 16px; }
  .city-dash .panel-top .hint { margin-bottom: 0; }
  .city-dash .seg { display: inline-flex; flex-shrink: 0; background: var(--panel);
    border: 1px solid var(--line); border-radius: 9px; padding: 3px; gap: 2px; }
  .city-dash .seg button { font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--ink-faint); background: none; border: none;
    padding: 7px 12px; border-radius: 6px; cursor: pointer; transition: all .18s var(--ease); }
  .city-dash .seg button:hover { color: var(--ink); }
  .city-dash .seg button.on { background: var(--paper); color: var(--ember);
    box-shadow: 0 1px 3px rgba(27,22,19,.1); }
  .city-dash .panel h3 { font-family: var(--serif); font-size: 21px; font-weight: 600; margin: 0 0 5px; }
  .city-dash .panel .hint { font-size: 13.5px; line-height: 1.5; color: var(--ink-faint); margin: 0 0 16px; max-width: 60ch; }
  .city-dash .grid2 { display: grid; grid-template-columns: 1fr; gap: 42px; }

  .city-dash .panel h3 em { font-style: italic; color: var(--ember); }
  .city-dash .chart { position: relative; }
  .city-dash .chart svg { display: block; width: 100%; height: auto; }
  .city-dash .emptynote { font-family: var(--serif); font-size: 17px; color: var(--ink-faint);
    padding: 40px 12px; text-align: center; margin: 0; }
  .city-dash .cax { font-family: var(--mono); font-size: 11px; fill: var(--ink-faint); }
  .city-dash .ctip {
    position: absolute; pointer-events: none; transform: translate(-50%, -118%);
    background: var(--ink); color: #fff; padding: 7px 10px; border-radius: 8px;
    font-family: var(--mono); font-size: 11.5px; line-height: 1.45; white-space: nowrap;
    box-shadow: 0 6px 20px -8px rgba(27,22,19,.5); z-index: 5;
  }
  .city-dash .ctip b { font-variant-numeric: tabular-nums; font-weight: 600; }
  .city-dash .legend { display: flex; gap: 20px; margin-top: 12px;
    font-family: var(--mono); font-size: 11.5px; color: var(--ink-soft); flex-wrap: wrap; letter-spacing: 0.02em; }
  .city-dash .legend i { display: inline-block; width: 22px; height: 3px; border-radius: 2px; vertical-align: middle; margin-right: 7px; }
  .city-dash .legend .sw { display: inline-block; width: 14px; height: 11px; border-radius: 2px; vertical-align: middle; margin-right: 7px; }
</style>

<script>
  const NS = "http://www.w3.org/2000/svg";
  function E(tag: string, attrs: Record<string, any> = {}, parent?: Element) {
    const e = document.createElementNS(NS, tag);
    for (const k in attrs) if (attrs[k] != null) e.setAttribute(k, String(attrs[k]));
    if (parent) parent.appendChild(e);
    return e;
  }
  const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  const CUM = [0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334];
  const fmtA = (v: number) => (v > 0 ? "+" : "") + v.toFixed(2);

  // soft-but-bright diverging ramp: teal-blue → cream → ember (matches the stripes)
  const STOPS: [number, number[]][] = [
    [-1, [31, 111, 139]], [-0.5, [116, 179, 201]], [0, [242, 236, 226]],
    [0.5, [232, 161, 75]], [1, [194, 59, 34]],
  ];
  function ramp(v: number, clamp: number) {
    const t = Math.max(-1, Math.min(1, v / clamp));
    let a = STOPS[0], b = STOPS[STOPS.length - 1];
    for (let i = 0; i < STOPS.length - 1; i++)
      if (t >= STOPS[i][0] && t <= STOPS[i + 1][0]) { a = STOPS[i]; b = STOPS[i + 1]; break; }
    const f = (t - a[0]) / (b[0] - a[0] || 1);
    const c = a[1].map((ai, i) => Math.round(ai + (b[1][i] - ai) * f));
    return `rgb(${c[0]},${c[1]},${c[2]})`;
  }

  // India-scale CMIP6 projection (embedded once), overlaid on every city as regional
  // context. Re-anchored per city to its current level in renderAnnual.
  const NAT_PROJ: { annual: { year: number; lo: number; hi: number; mean: number }[] } | null =
    (() => { try { return JSON.parse(document.querySelector("[data-projection]")?.textContent || "null"); } catch { return null; } })();

  function initCityDash(root: HTMLElement) {
    const combo = root.querySelector("[data-combo]") as HTMLElement;
    const cInput = combo.querySelector(".combo-input") as HTMLInputElement;
    const cList = combo.querySelector("[data-combo-list]") as HTMLElement;
    const cOpts = Array.from(cList.querySelectorAll<HTMLElement>(".combo-opt"));
    const elMeta = root.querySelector("[data-meta]") as HTMLElement;
    const elStats = root.querySelector("[data-stats]") as HTMLElement;
    const elBand = root.querySelector("[data-band]") as HTMLElement;
    const elBandTitle = root.querySelector("[data-band-title]") as HTMLElement;
    const elBandLegend = root.querySelector("[data-band-legend]") as HTMLElement;
    const elHeat = root.querySelector("[data-heat]") as HTMLElement;
    const elAnnual = root.querySelector("[data-annual]") as HTMLElement;
    const elHHeat = root.querySelector("[data-hheat]") as HTMLElement;
    const elHHeatLegend = root.querySelector("[data-hheat-legend]") as HTMLElement;
    const elSrc = root.querySelector("[data-src]") as HTMLElement;
    const elBandHint = root.querySelector("[data-band-hint]") as HTMLElement;
    const segBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-bandmode] button"));
    const views = root.querySelector("[data-views]") as HTMLElement;
    let first = true;
    let bandMode: "spaghetti" | "band" = "spaghetti";
    let currentData: any = null;

    async function load(id: string) {
      const data = await fetch(`/data/cities/${id}.json`).then((r) => r.json());
      if (first) { render(data); first = false; return; }
      views.classList.add("swapping");
      setTimeout(() => {
        render(data);
        requestAnimationFrame(() => views.classList.remove("swapping"));
      }, 200);
    }

    function render(d: any) {
      currentData = d;
      elMeta.innerHTML = `<b>${d.name}</b> · ${d.region} · ${d.recordStart}–${d.latestYear} · ${d.lat.toFixed(2)}°N, ${d.lon.toFixed(2)}°E`;
      elSrc.innerHTML = `Source: <a href="${d.source.url}" target="_blank" rel="noopener">${d.source.name}</a> daily reanalysis, ${d.recordStart}–${d.latestYear}. Anomalies vs the ${d.baseline} average.`;
      renderStats(d);
      renderBandArea();
      renderHeat(d);
      renderAnnual(d);
      renderHumidHeat(d);
    }

    function renderBandArea() {
      const d = currentData;
      if (!d) return;
      if (bandMode === "spaghetti") {
        elBandTitle.textContent = `${d.currentYear.year} against every year — ${d.name}`;
        elBandHint.textContent = "Every year since 1950 as a faint line; the recent years picked out. Hover to read any day.";
        renderSpaghetti(d);
      } else {
        elBandTitle.textContent = `${d.currentYear.year} vs normal — ${d.name}`;
        elBandHint.textContent = "Shaded band = the normal range (10th–90th percentile, 1991–2020). Bold line = this year so far. Hover to read any day.";
        renderBand(d);
      }
    }

    for (const b of segBtns) {
      b.addEventListener("click", () => {
        const m = b.dataset.mode as "spaghetti" | "band";
        if (m === bandMode) return;
        bandMode = m;
        segBtns.forEach((x) => x.classList.toggle("on", x === b));
        renderBandArea();
      });
    }

    function renderStats(d: any) {
      const recent = d.annual.slice(-10);
      const recentAvg = recent.reduce((s: number, p: any) => s + p.value, 0) / recent.length;
      const hd = d.stats;
      const trend = hd.hotDaysRecentAvg != null && hd.hotDaysBaselineAvg != null
        ? hd.hotDaysRecentAvg - hd.hotDaysBaselineAvg : null;
      const cards = [
        { warm: true, v: `${fmtA(recentAvg)}°C`, k: `warmer than normal, last 10 years` },
        { v: hd.hottestDay ? `${hd.hottestDay.value}°C` : "—", k: hd.hottestDay ? `hottest day on record (${hd.hottestDay.date})` : "hottest day" },
        { v: hd.hotDaysRecentAvg != null ? `${hd.hotDaysRecentAvg}` : "—",
          k: `days ≥ ${hd.hotThreshold}°C a year now${trend != null ? ` (${trend >= 0 ? "+" : ""}${trend} vs 1991–2020)` : ""}` },
      ];
      elStats.innerHTML = "";
      for (const c of cards) {
        const s = document.createElement("div");
        s.className = "s" + (c.warm ? " warm" : "");
        s.innerHTML = `<span class="v">${c.v}</span><span class="k">${c.k}</span>`;
        elStats.appendChild(s);
      }
    }

    // "Every year" spaghetti: all years since 1950 as faint weekly curves, with
    // the three most recent picked out and this year boldest.
    function renderSpaghetti(d: any) {
      const W = 780, H = 320, M = { t: 14, r: 14, b: 26, l: 34 };
      const iw = W - M.l - M.r, ih = H - M.t - M.b;
      const years = d.weekly.years as number[], series = d.weekly.series as (number | null)[][];
      const latest = d.currentYear.year;
      let lo = Infinity, hi = -Infinity;
      for (const yr of series) for (const v of yr) if (v != null) { lo = Math.min(lo, v); hi = Math.max(hi, v); }
      lo = Math.floor(lo - 1); hi = Math.ceil(hi + 1);
      const x = (wk: number) => M.l + (wk / 51) * iw;
      const y = (t: number) => M.t + ((hi - t) / (hi - lo)) * ih;

      elBand.innerHTML = "";
      const svg = E("svg", { viewBox: `0 0 ${W} ${H}`, role: "img" }, elBand);
      const step = (hi - lo) > 24 ? 10 : 5;
      for (let t = Math.ceil(lo / step) * step; t <= hi; t += step) {
        E("line", { x1: M.l, x2: W - M.r, y1: y(t), y2: y(t), stroke: "#ece6dd" }, svg);
        E("text", { x: M.l - 6, y: y(t), dy: "0.32em", "text-anchor": "end", class: "cax" }, svg).textContent = `${t}°`;
      }
      for (let m = 0; m < 12; m++) {
        const wk = Math.min(51, (CUM[m] + 15) / 7);
        E("text", { x: x(wk), y: H - 8, "text-anchor": "middle", class: "cax" }, svg).textContent = MONTHS[m][0];
      }
      const pathFor = (arr: (number | null)[]) => {
        let p = "", pen = false;
        for (let i = 0; i < arr.length; i++) {
          const v = arr[i]; if (v == null) { pen = false; continue; }
          p += `${pen ? "L" : "M"}${x(i).toFixed(1)},${y(v).toFixed(1)}`; pen = true;
        }
        return p;
      };
      const HL: Record<number, { c: string; w: number; o: string }> = {
        [latest]: { c: "#cf4321", w: 2.4, o: "1" },
        [latest - 1]: { c: "#e8843c", w: 1.6, o: ".95" },
        [latest - 2]: { c: "#2a7da3", w: 1.5, o: ".9" },
      };
      years.forEach((yr, i) => {
        if (HL[yr]) return;
        E("path", { d: pathFor(series[i]), fill: "none", stroke: "#d8cfc4", "stroke-width": 0.7, "stroke-opacity": .5, "stroke-linejoin": "round" }, svg);
      });
      [latest - 2, latest - 1, latest].forEach((yr) => {
        const i = years.indexOf(yr); if (i < 0) return; const s = HL[yr];
        E("path", { d: pathFor(series[i]), fill: "none", stroke: s.c, "stroke-width": s.w, "stroke-opacity": s.o, "stroke-linejoin": "round", "stroke-linecap": "round" }, svg);
      });

      const tip = document.createElement("div"); tip.className = "ctip"; tip.hidden = true; elBand.appendChild(tip);
      const cap = E("rect", { x: M.l, y: M.t, width: iw, height: ih, fill: "transparent", style: "cursor:crosshair" }, svg);
      const mk = E("line", { y1: M.t, y2: H - M.b, stroke: "#999", "stroke-dasharray": "3 3", opacity: 0 }, svg);
      const latestSeries = series[years.indexOf(latest)] || [];
      cap.addEventListener("pointermove", (evt: any) => {
        const p = (svg as any).createSVGPoint(); p.x = evt.clientX; p.y = evt.clientY;
        const loc = p.matrixTransform((svg as any).getScreenCTM().inverse());
        let wk = Math.round(((loc.x - M.l) / iw) * 51); wk = Math.max(0, Math.min(51, wk));
        const cv = latestSeries[wk];
        mk.setAttribute("x1", String(x(wk))); mk.setAttribute("x2", String(x(wk))); mk.setAttribute("opacity", "1");
        const dt = new Date(latest, 0, wk * 7 + 4);
        tip.innerHTML = `<b>${MONTHS[dt.getMonth()]}</b><br>${cv != null ? `${latest}: <b>${cv}°</b>` : `${latest}: –`}`;
        const rect = svg.getBoundingClientRect();
        tip.style.left = `${(x(wk) / W) * rect.width}px`;
        tip.style.top = `${(y(cv ?? (lo + hi) / 2) / H) * rect.height}px`;
        tip.hidden = false;
      });
      cap.addEventListener("pointerleave", () => { tip.hidden = true; mk.setAttribute("opacity", "0"); });

      elBandLegend.innerHTML =
        `<span><i style="background:#cf4321"></i>${latest}</span>` +
        `<span><i style="background:#e8843c"></i>${latest - 1}</span>` +
        `<span><i style="background:#2a7da3"></i>${latest - 2}</span>` +
        `<span><i style="background:#d8cfc4"></i>every year ${years[0]}–${latest}</span>`;
    }

    function renderBand(d: any) {
      const W = 780, H = 320, M = { t: 14, r: 14, b: 26, l: 34 };
      const iw = W - M.l - M.r, ih = H - M.t - M.b;
      const clim = d.clim, cur = d.currentYear.daily, prev = d.previousYear.daily;
      let lo = Infinity, hi = -Infinity;
      for (const c of clim) if (c) { lo = Math.min(lo, c.p10); hi = Math.max(hi, c.p90); }
      for (const v of cur) if (v != null) { lo = Math.min(lo, v); hi = Math.max(hi, v); }
      lo = Math.floor(lo - 1); hi = Math.ceil(hi + 1);
      const x = (doy: number) => M.l + ((doy - 1) / 364) * iw;
      const y = (t: number) => M.t + ((hi - t) / (hi - lo)) * ih;

      elBand.innerHTML = "";
      const svg = E("svg", { viewBox: `0 0 ${W} ${H}`, role: "img" }, elBand);
      // y gridlines
      const step = (hi - lo) > 24 ? 10 : 5;
      for (let t = Math.ceil(lo / step) * step; t <= hi; t += step) {
        E("line", { x1: M.l, x2: W - M.r, y1: y(t), y2: y(t), stroke: "#ece6dd" }, svg);
        E("text", { x: M.l - 6, y: y(t), dy: "0.32em", "text-anchor": "end", class: "cax" }, svg).textContent = `${t}°`;
      }
      // month ticks
      for (let m = 0; m < 12; m++) {
        const cx = x(CUM[m] + 15);
        E("text", { x: cx, y: H - 8, "text-anchor": "middle", class: "cax" }, svg).textContent = MONTHS[m][0];
      }
      // band area (p90 top, p10 bottom)
      let top = "", bot = "";
      for (let i = 0; i < 365; i++) { const c = clim[i]; if (!c) continue;
        top += `${top ? "L" : "M"}${x(i + 1).toFixed(1)},${y(c.p90).toFixed(1)}`;
        bot = `L${x(i + 1).toFixed(1)},${y(c.p10).toFixed(1)}` + bot.replace(/^L/, "L"); }
      // rebuild bottom in reverse properly
      bot = "";
      for (let i = 364; i >= 0; i--) { const c = clim[i]; if (!c) continue; bot += `L${x(i + 1).toFixed(1)},${y(c.p10).toFixed(1)}`; }
      E("path", { d: top + bot + "Z", fill: "#cf4321", "fill-opacity": ".11", stroke: "none" }, svg);
      // normal mean line
      let meanP = "";
      for (let i = 0; i < 365; i++) { const c = clim[i]; if (!c) continue; meanP += `${meanP ? "L" : "M"}${x(i + 1).toFixed(1)},${y(c.mean).toFixed(1)}`; }
      E("path", { d: meanP, fill: "none", stroke: "#b9aa9b", "stroke-width": 1.3, "stroke-dasharray": "1 3", "stroke-linecap": "round" }, svg);
      // previous year (faint)
      drawYearLine(svg, prev, x, y, "#c9b8a8", 1, ".75");
      // current year (bold accent)
      drawYearLine(svg, cur, x, y, "#cf4321", 2.4, "1");

      // hover
      const tip = document.createElement("div"); tip.className = "ctip"; tip.hidden = true; elBand.appendChild(tip);
      const cap = E("rect", { x: M.l, y: M.t, width: iw, height: ih, fill: "transparent", style: "cursor:crosshair" }, svg);
      const mk = E("line", { y1: M.t, y2: H - M.b, stroke: "#999", "stroke-dasharray": "3 3", opacity: 0 }, svg);
      cap.addEventListener("pointermove", (evt: any) => {
        const p = (svg as any).createSVGPoint(); p.x = evt.clientX; p.y = evt.clientY;
        const loc = p.matrixTransform((svg as any).getScreenCTM().inverse());
        let doy = Math.round(((loc.x - M.l) / iw) * 364) + 1; doy = Math.max(1, Math.min(365, doy));
        const c = clim[doy - 1]; const cv = cur[doy - 1];
        mk.setAttribute("x1", String(x(doy))); mk.setAttribute("x2", String(x(doy))); mk.setAttribute("opacity", "1");
        const dt = new Date(d.currentYear.year, 0, doy);
        const dateStr = `${dt.getDate()} ${MONTHS[dt.getMonth()]}`;
        tip.innerHTML = `<b>${dateStr}</b><br>${cv != null ? `this year <b>${cv}°</b><br>` : ""}normal ${c ? c.mean : "–"}°`;
        const rect = svg.getBoundingClientRect();
        tip.style.left = `${(x(doy) / W) * rect.width}px`;
        tip.style.top = `${(y(cv ?? (c ? c.mean : lo)) / H) * rect.height}px`;
        tip.hidden = false;
      });
      cap.addEventListener("pointerleave", () => { tip.hidden = true; mk.setAttribute("opacity", "0"); });

      elBandLegend.innerHTML =
        `<span><i style="background:#cf4321"></i>${d.currentYear.year}</span>` +
        `<span><i style="background:#c9b8a8"></i>${d.previousYear.year}</span>` +
        `<span><i style="background:#b9aa9b"></i>1991–2020 normal</span>` +
        `<span><span class="sw" style="background:#f4ddd3"></span>normal range</span>`;
    }

    function drawYearLine(svg: Element, arr: (number | null)[], x: any, y: any, color: string, w: number, op: string) {
      let p = "", pen = false;
      for (let i = 0; i < arr.length; i++) {
        const v = arr[i]; if (v == null) { pen = false; continue; }
        p += `${pen ? "L" : "M"}${x(i + 1).toFixed(1)},${y(v).toFixed(1)}`; pen = true;
      }
      E("path", { d: p, fill: "none", stroke: color, "stroke-width": w, "stroke-opacity": op, "stroke-linejoin": "round" }, svg);
    }

    // Landscape monthly heatmap: years run left→right, months top→bottom, so it
    // fills the full content width like a climate stripe-grid.
    function renderHeat(d: any) {
      const years = d.monthly.years, grid = d.monthly.grid;
      const gut = { l: 34, t: 16, b: 4 };
      const cw = Math.max(8, Math.min(15, 960 / years.length));
      const ch = 19;
      const W = gut.l + years.length * cw + 4, H = gut.t + 12 * ch + gut.b;
      elHeat.innerHTML = "";
      const svg = E("svg", { viewBox: `0 0 ${W} ${H}`, role: "img",
        "aria-label": `Monthly temperature anomalies for ${d.name}` }, elHeat);
      // month labels down the left
      for (let m = 0; m < 12; m++)
        E("text", { x: gut.l - 7, y: gut.t + m * ch + ch / 2, dy: "0.32em", "text-anchor": "end", class: "cax" }, svg)
          .textContent = MONTHS[m].slice(0, 1);
      // year labels along the top, every decade
      years.forEach((yr: number, c: number) => {
        if (yr % 10 === 0) E("text", { x: gut.l + c * cw + cw / 2, y: 10, "text-anchor": "middle", class: "cax" }, svg).textContent = String(yr);
        for (let m = 0; m < 12; m++) {
          const v = grid[c][m];
          const rect = E("rect", { x: gut.l + c * cw, y: gut.t + m * ch, width: Math.max(1, cw - 0.4), height: ch - 0.6,
            fill: v == null ? "#f3efe8" : ramp(v, 3) }, svg);
          if (v != null) E("title", {}, rect).textContent = `${MONTHS[m]} ${yr}: ${fmtA(v)}°C`;
        }
      });
    }

    function renderAnnual(d: any) {
      const data = d.annual; if (!data.length) { elAnnual.innerHTML = ""; return; }
      const W = 940, H = 300, M = { t: 14, r: 14, b: 26, l: 36 };
      const iw = W - M.l - M.r, ih = H - M.t - M.b;
      const lastObs = data[data.length - 1];
      // city's smoothed "now" level (last ~10-yr mean) — the anchor for the projection cone
      const smWin = data.slice(Math.max(0, data.length - 10));
      const cityNow = smWin.reduce((s: number, p: any) => s + p.value, 0) / smWin.length;
      // India-scale CMIP6 projection, re-anchored to this city's current level: we add the
      // projected *regional rise* on top of where the city is now, so the cone continues
      // its own line and fans out with scenario uncertainty (SSP2-4.5 ↔ SSP5-8.5).
      const natAnnual = (d.projection?.annual?.length ? d.projection.annual : NAT_PROJ?.annual) as
        { year: number; lo: number; hi: number; mean: number }[] | undefined;
      let proj: { year: number; mean: number; lo: number; hi: number }[] = [];
      if (natAnnual && natAnnual.length) {
        const anchor = natAnnual.find((p) => p.year === lastObs.year)
          || natAnnual.reduce((best, p) => Math.abs(p.year - lastObs.year) < Math.abs(best.year - lastObs.year) ? p : best);
        const r = (v: number) => Math.round(v * 100) / 100;
        proj = natAnnual.filter((p) => p.year > lastObs.year).map((p) => ({
          year: p.year,
          mean: r(cityNow + (p.mean - anchor.mean)),
          lo: r(cityNow + (p.lo - anchor.lo)),
          hi: r(cityNow + (p.hi - anchor.hi)),
        }));
      }
      const ys = data.map((p: any) => p.year), vs = data.map((p: any) => p.value);
      const y0 = Math.min(...ys);
      const y1 = Math.max(...ys, ...proj.map((p) => p.year));
      let lo = Math.min(...vs, ...proj.map((p) => p.lo), 0) - 0.2;
      let hi = Math.max(...vs, ...proj.map((p) => p.hi), 0) + 0.2;
      lo = Math.floor(lo * 2) / 2; hi = Math.ceil(hi * 2) / 2;
      const x = (yr: number) => M.l + ((yr - y0) / (y1 - y0)) * iw;
      const y = (v: number) => M.t + ((hi - v) / (hi - lo)) * ih;
      elAnnual.innerHTML = "";
      const svg = E("svg", { viewBox: `0 0 ${W} ${H}`, role: "img" }, elAnnual);
      for (let v = lo; v <= hi + 1e-9; v += 0.5) {
        E("line", { x1: M.l, x2: W - M.r, y1: y(v), y2: y(v), stroke: v === 0 ? "#cfcfcf" : "#eee", "stroke-width": v === 0 ? 1.2 : 1 }, svg);
        E("text", { x: M.l - 6, y: y(v), dy: "0.32em", "text-anchor": "end", class: "cax" }, svg).textContent = (v > 0 ? "+" : "") + v;
      }
      const xStep = y1 - y0 > 90 ? 20 : 10;
      for (let yr = Math.ceil(y0 / xStep) * xStep; yr <= y1; yr += xStep) E("text", { x: x(yr), y: H - 8, "text-anchor": "middle", class: "cax" }, svg).textContent = String(yr);
      // projection band: multi-model spread ribbon + dashed ensemble-mean, drawn first (behind observed)
      if (proj.length) {
        // cone starts at the city's current level (cityNow) and fans out into the future
        const seq = [{ year: lastObs.year, mean: cityNow, lo: cityNow, hi: cityNow }, ...proj];
        const top = seq.map((p) => `${x(p.year).toFixed(1)},${y(p.hi).toFixed(1)}`);
        const bot = seq.map((p) => `${x(p.year).toFixed(1)},${y(p.lo).toFixed(1)}`).reverse();
        E("polygon", { points: [...top, ...bot].join(" "), fill: "#cf4321", "fill-opacity": ".10", stroke: "none" }, svg);
        E("path", { d: seq.map((p, i) => `${i ? "L" : "M"}${x(p.year).toFixed(1)},${y(p.mean).toFixed(1)}`).join(""),
          fill: "none", stroke: "#cf4321", "stroke-width": 1.6, "stroke-dasharray": "5 4", "stroke-opacity": ".75" }, svg);
        // "now" divider + label
        E("line", { x1: x(lastObs.year), x2: x(lastObs.year), y1: M.t, y2: H - M.b, stroke: "#bbb", "stroke-width": 1, "stroke-dasharray": "2 3" }, svg);
        E("text", { x: x(lastObs.year) + 5, y: M.t + 11, class: "cax", "text-anchor": "start" }, svg).textContent = "India CMIP6 projection →";
        const end = proj[proj.length - 1];
        E("text", { x: x(end.year), y: y(end.hi) - 6, class: "cax", "text-anchor": "end", "font-weight": "600", fill: "#cf4321" }, svg)
          .textContent = `${end.year}: ${end.mean > 0 ? "+" : ""}${end.mean}°C`;
      }
      // 10-yr smooth (observed)
      const sm = data.map((p: any, i: number) => {
        const lo2 = Math.max(0, i - 5), hi2 = Math.min(data.length - 1, i + 4), w = data.slice(lo2, hi2 + 1);
        return { year: p.year, value: w.reduce((s: number, q: any) => s + q.value, 0) / w.length };
      });
      E("path", { d: sm.map((p: any, i: number) => `${i ? "L" : "M"}${x(p.year).toFixed(1)},${y(p.value).toFixed(1)}`).join(""),
        fill: "none", stroke: "#cf4321", "stroke-opacity": ".26", "stroke-width": 6, "stroke-linecap": "round" }, svg);
      E("path", { d: data.map((p: any, i: number) => `${i ? "L" : "M"}${x(p.year).toFixed(1)},${y(p.value).toFixed(1)}`).join(""),
        fill: "none", stroke: "#cf4321", "stroke-width": 1.6 }, svg);
      E("circle", { cx: x(lastObs.year), cy: y(lastObs.value), r: 3.5, fill: "#cf4321", stroke: "#fff", "stroke-width": 1.4 }, svg);
    }

    // Humid-heat "feels like" danger days: amber bars (>=40), ember base (>=45), trend.
    function renderHumidHeat(d: any) {
      const data = (d.humidHeat || []) as { year: number; d40: number; d45: number }[];
      elHHeat.innerHTML = ""; elHHeatLegend.innerHTML = "";
      const maxV = data.reduce((m, p) => Math.max(m, p.d40), 0);
      if (maxV < 2) {
        elHHeat.innerHTML = `<p class="emptynote">${d.name} hardly ever feels hotter than 40°C — too high up, or too mild. That is its own kind of lucky.</p>`;
        return;
      }
      const W = 940, H = 300, M = { t: 14, r: 14, b: 26, l: 36 };
      const iw = W - M.l - M.r, ih = H - M.t - M.b;
      const ys = data.map((p) => p.year), y0 = Math.min(...ys), y1 = Math.max(...ys);
      const hi = Math.max(20, Math.ceil(maxV / 20) * 20);
      const x = (yr: number) => M.l + ((yr - y0) / (y1 - y0)) * iw;
      const y = (v: number) => M.t + ((hi - v) / hi) * ih;
      const bw = Math.max(1.5, iw / data.length - 1.2);
      const svg = E("svg", { viewBox: `0 0 ${W} ${H}`, role: "img" }, elHHeat);
      const stepY = hi > 120 ? 40 : hi > 60 ? 20 : 10;
      for (let v = 0; v <= hi; v += stepY) {
        E("line", { x1: M.l, x2: W - M.r, y1: y(v), y2: y(v), stroke: "#ece6dd" }, svg);
        E("text", { x: M.l - 6, y: y(v), dy: "0.32em", "text-anchor": "end", class: "cax" }, svg).textContent = String(v);
      }
      for (const yr of ys) if (yr % 10 === 0) E("text", { x: x(yr), y: H - 8, "text-anchor": "middle", class: "cax" }, svg).textContent = String(yr);
      for (const p of data) {
        const cx = x(p.year) - bw / 2;
        const r1 = E("rect", { x: cx, y: y(p.d40), width: bw, height: y(0) - y(p.d40), fill: "#e8a14b" }, svg);
        E("title", {}, r1).textContent = `${p.year}: ${p.d40} days felt ≥40°, ${p.d45} felt ≥45°`;
        if (p.d45 > 0) E("rect", { x: cx, y: y(p.d45), width: bw, height: y(0) - y(p.d45), fill: "#c23b22" }, svg);
      }
      const sm = data.map((p, i) => {
        const lo = Math.max(0, i - 5), h = Math.min(data.length - 1, i + 4), w = data.slice(lo, h + 1);
        return { year: p.year, v: w.reduce((s, q) => s + q.d40, 0) / w.length };
      });
      E("path", { d: sm.map((p, i) => `${i ? "L" : "M"}${x(p.year).toFixed(1)},${y(p.v).toFixed(1)}`).join(""),
        fill: "none", stroke: "#7a2414", "stroke-width": 1.8, "stroke-opacity": .7, "stroke-linejoin": "round" }, svg);
      elHHeatLegend.innerHTML =
        `<span><span class="sw" style="background:#e8a14b"></span>feels ≥40°C</span>` +
        `<span><span class="sw" style="background:#c23b22"></span>feels ≥45°C</span>` +
        `<span><i style="background:#7a2414"></i>10-yr trend</span>`;
    }

    let activeIdx = -1;
    function openList(filter = "") {
      const q = filter.trim().toLowerCase();
      let shown = 0;
      for (const o of cOpts) {
        const match = !q || (o.dataset.search || "").includes(q);
        o.hidden = !match; if (match) shown++; o.classList.remove("active");
      }
      cList.hidden = shown === 0; activeIdx = -1;
    }
    function selectOpt(o: HTMLElement) {
      cInput.value = (o.querySelector(".opt-name") as HTMLElement).textContent || "";
      cList.hidden = true; activeIdx = -1;
      load(o.dataset.id!);
    }
    cInput.addEventListener("focus", () => { cInput.select(); openList(""); });
    cInput.addEventListener("input", () => openList(cInput.value));
    cInput.addEventListener("keydown", (e) => {
      const vis = cOpts.filter((o) => !o.hidden);
      if (e.key === "ArrowDown") { e.preventDefault(); activeIdx = Math.min(vis.length - 1, activeIdx + 1); }
      else if (e.key === "ArrowUp") { e.preventDefault(); activeIdx = Math.max(0, activeIdx - 1); }
      else if (e.key === "Enter") { e.preventDefault(); if (vis[activeIdx]) selectOpt(vis[activeIdx]); else if (vis.length === 1) selectOpt(vis[0]); return; }
      else if (e.key === "Escape") { cList.hidden = true; return; }
      else return;
      vis.forEach((o, i) => o.classList.toggle("active", i === activeIdx));
      if (vis[activeIdx]) vis[activeIdx].scrollIntoView({ block: "nearest" });
    });
    for (const o of cOpts) o.addEventListener("mousedown", (e) => { e.preventDefault(); selectOpt(o); });
    document.addEventListener("click", (e) => { if (!combo.contains(e.target as Node)) cList.hidden = true; });

    cInput.value = root.dataset.defaultName || "";
    load(root.dataset.default!);
  }

  document.querySelectorAll<HTMLElement>(".city-dash").forEach(initCityDash);
</script>
