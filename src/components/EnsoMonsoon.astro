---
// ENSO vs monsoon: per-year all-India June–September rainfall departure, each bar
// coloured by the El Niño / La Niña state during that monsoon (NOAA ONI).
import enso from "../data/enso.json";
import Explainer from "./Explainer.astro";
const { rows, source, monsoon, elNino, laNina } = enso;

const phaseColor = (p: string) => (p === "El Nino" ? "#cf4321" : p === "La Nina" ? "#2a7da3" : "#cabfb0");

const W = 940, H = 360, M = { t: 18, r: 14, b: 30, l: 40 };
const iw = W - M.l - M.r, ih = H - M.t - M.b;
const y0 = rows[0].year, y1 = rows[rows.length - 1].year;
const maxAbs = Math.max(...rows.map((r: any) => Math.abs(r.departure)), 20);
const dMax = Math.ceil(maxAbs / 10) * 10;
const x = (yr: number) => M.l + ((yr - y0) / (y1 - y0)) * iw;
const y = (v: number) => M.t + ((dMax - v) / (2 * dMax)) * ih;
const bw = Math.max(2, iw / rows.length - 1.4);
const zeroY = y(0);
const yTicks: number[] = [];
for (let v = -dMax; v <= dMax + 1e-9; v += 10) yTicks.push(v);
const pts = rows.map((r: any) => ({ ...r, px: +x(r.year).toFixed(1) }));
---

<section class="section enso">
  <div class="section-head">
    <p class="eyebrow">What moves the monsoon</p>
    <h2>The Pacific has a hand on India's rain</h2>
    <p class="standfirst">
      Each bar is one monsoon's all-India rainfall, above or below normal, coloured by whether the
      Pacific was in an <strong>El Niño</strong> (warm) or <strong>La Niña</strong> (cool) state that
      summer. El Niño years lean dry; La Niña years lean wet.
    </p>
  </div>

  <p class="enso-stat mono">
    El Niño monsoons since {y0}: <b class="en">{elNino.mean > 0 ? "+" : ""}{elNino.mean}%</b> on average ·
    La Niña monsoons: <b class="ln">{laNina.mean > 0 ? "+" : ""}{laNina.mean}%</b>
  </p>

  <figure class="enso-chart" data-points={JSON.stringify(pts)}>
    <div class="plot">
      <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="All-India monsoon rainfall departure by year, coloured by ENSO phase">
        {yTicks.map((v) => (
          <g>
            <line class={v === 0 ? "grid zero" : "grid"} x1={M.l} x2={W - M.r} y1={y(v)} y2={y(v)} stroke-width={v === 0 ? 1.3 : 1} />
            <text x={M.l - 7} y={y(v)} dy="0.32em" text-anchor="end" class="cax">{v > 0 ? `+${v}` : v}</text>
          </g>
        ))}
        {rows.filter((r: any) => r.year % 10 === 0).map((r: any) => (
          <text x={x(r.year)} y={H - 12} text-anchor="middle" class="cax">{r.year}</text>
        ))}
        <text x={M.l} y={M.t - 4} class="cax muted">% vs normal monsoon</text>
        {rows.map((r: any) => (
          <rect x={x(r.year) - bw / 2} y={Math.min(zeroY, y(r.departure))}
                width={bw} height={Math.abs(y(r.departure) - zeroY)}
                fill={phaseColor(r.phase)} rx="0.6" />
        ))}
        <g class="marker" style="opacity:0">
          <line class="mline" y1={M.t} y2={H - M.b} stroke="#999" stroke-width="1" stroke-dasharray="3 3" />
        </g>
        <rect class="capture" x={M.l} y={M.t} width={iw} height={ih} fill="transparent" />
      </svg>
      <div class="tip" hidden></div>
    </div>
    <div class="legend">
      <span><i style="background:#cf4321"></i>El Niño year</span>
      <span><i style="background:#2a7da3"></i>La Niña year</span>
      <span><i style="background:#cabfb0"></i>Neutral</span>
    </div>
  </figure>
  <p class="fignote">
    Source: <a href={source.url} target="_blank" rel="noopener">{source.name}</a> for the ENSO state;
    {" "}{monsoon}.
  </p>

  <Explainer>
    El Niño is just an unusually warm patch of the central Pacific, half a world away, but it drags
    the band of tropical rain eastward, away from India, and the monsoon tends to come up short.
    La Niña does the opposite. <strong>It is a loading of the dice, not a script</strong>: most of
    India's worst drought years were El Niño years, yet plenty of El Niño summers still delivered a
    perfectly good monsoon. The Pacific tilts the odds; it doesn't decide.
  </Explainer>
</section>

<style>
  .enso-stat { font-size: 14px; color: var(--ink-soft); margin: 0 0 18px; letter-spacing: 0.01em; }
  .enso-stat b { font-weight: 600; }
  .enso-stat .en { color: #cf4321; }
  .enso-stat .ln { color: #2a7da3; }
  .enso-chart { margin: 0; }
  .enso-chart .plot { position: relative; }
  .enso-chart svg { display: block; width: 100%; height: auto; }
  .enso-chart .cax.muted { fill: #c2b4a6; font-size: 11px; }
  .enso-chart .capture { cursor: crosshair; }
  .enso-chart .legend { display: flex; gap: 20px; margin-top: 12px;
    font-family: var(--mono); font-size: 11.5px; color: var(--ink-soft); flex-wrap: wrap; }
  .enso-chart .legend i { display: inline-block; width: 14px; height: 11px; border-radius: 2px; vertical-align: middle; margin-right: 7px; }
  .enso-chart .tip {
    position: absolute; pointer-events: none; transform: translate(-50%, -120%);
    background: var(--ink); color: #fff; padding: 7px 10px; border-radius: 8px;
    font-family: var(--mono); font-size: 11.5px; line-height: 1.45; white-space: nowrap;
    box-shadow: 0 6px 20px -8px rgba(27,22,19,.5); z-index: 5;
  }
  .enso-chart .tip b { font-weight: 600; }
</style>

<script>
  function initEnso(fig: HTMLElement) {
    const svg = fig.querySelector("svg") as SVGSVGElement;
    const cap = fig.querySelector(".capture") as SVGRectElement;
    const marker = fig.querySelector(".marker") as SVGGElement;
    const mline = fig.querySelector(".mline") as SVGLineElement;
    const tip = fig.querySelector(".tip") as HTMLElement;
    const pts = JSON.parse(fig.dataset.points || "[]") as
      { year: number; departure: number; oni: number; phase: string; px: number }[];
    if (!pts.length) return;
    const COL: Record<string, string> = { "El Nino": "#cf4321", "La Nina": "#2a7da3", "Neutral": "#9a8e7e" };
    cap.addEventListener("pointermove", (evt: any) => {
      const p = svg.createSVGPoint(); p.x = evt.clientX; p.y = evt.clientY;
      const loc = p.matrixTransform(svg.getScreenCTM()!.inverse());
      let best = pts[0], bd = Infinity;
      for (const pt of pts) { const dd = Math.abs(pt.px - loc.x); if (dd < bd) { bd = dd; best = pt; } }
      marker.style.opacity = "1";
      mline.setAttribute("x1", String(best.px)); mline.setAttribute("x2", String(best.px));
      const sign = best.departure > 0 ? "+" : "";
      const label = best.phase === "El Nino" ? "El Niño" : best.phase === "La Nina" ? "La Niña" : "Neutral";
      tip.innerHTML = `<b>${best.year}</b> · ${sign}${best.departure}% rain<br><span style="color:${COL[best.phase]}">${label}</span> · ONI ${best.oni > 0 ? "+" : ""}${best.oni}`;
      const rect = svg.getBoundingClientRect();
      tip.style.left = `${(best.px / svg.viewBox.baseVal.width) * rect.width}px`;
      tip.style.top = `${0.18 * rect.height}px`;
      tip.hidden = false;
    });
    cap.addEventListener("pointerleave", () => { marker.style.opacity = "0"; tip.hidden = true; });
  }
  document.querySelectorAll<HTMLElement>(".enso-chart").forEach(initEnso);
</script>
