---
import "../styles/global.css";
import { readFileSync } from "node:fs";
// Inline the self-hosted @font-face rules at build time: no external Google Fonts
// round-trips (preconnect + CSS + fonts → just our own edge), and zero extra request
// for the font stylesheet itself. woff2 files live in /public/fonts, served from edge.
const fontCss = readFileSync("public/fonts/fonts.css", "utf8");
interface Props { title?: string; description?: string; }
const {
  title = "India Climate Monitor — how hot is India getting?",
  description = "A live, editorial temperature record for India and 148 of its cities, built on ERA5 (Copernicus), Berkeley Earth and Open-Meteo reanalysis.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#cf4321" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- preload the two primary variable fonts (heading + body); mono is non-critical -->
    <link rel="preload" as="font" type="font/woff2" crossorigin
      href="/fonts/6NU78FyLNQOQZAnv9bYEvDiIdE9Ea92uemAk_WBq8U_9v0c2Wa0KxC9TeA.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin
      href="/fonts/ieVn2YZDLWuGJpnzaiwFXS9tYtpd59A.woff2" />
    <style set:html={fontCss}></style>
  </head>
  <body>
    <div class="wrap">
      <header class="masthead">
        <span class="brand">India Climate Monitor</span>
        <span class="live"><span class="dot"></span> tracking</span>
      </header>
      <slot />
      <footer class="sitefoot">
        <a href="https://thisindianlife.today">← This Indian Life</a>
        <span>climate.thisindianlife.today</span>
      </footer>
    </div>
  </body>
</html>
