# Cloudflare edge cache rules (honored from dist/_headers).

# Hashed build assets + fonts never change for a given URL → cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# City/national data: changes on the weekly refresh. Cache an hour, but serve stale
# instantly while revalidating in the background — fast repeat loads, never stale-stuck.
/data/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=604800

# NB: no catch-all /* rule. Cloudflare CONCATENATES every matching rule's headers, so a
# /* Cache-Control would prepend onto /_astro, /fonts and /data and corrupt them
# (e.g. "max-age=0 ... max-age=31536000" → browsers take the first, killing immutable).
# HTML keeps the Workers-assets default (revalidate-friendly), which is what we want.
